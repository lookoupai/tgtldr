# Optional. If left empty, TGTLDR will generate a random key on first start
# and persist it to /var/lib/tgtldr/master.key inside the app volume.
# Set it explicitly only if you want to manage the key yourself.
TGTLDR_MASTER_KEY=

# Optional host port overrides for Docker Compose.
TGTLDR_HOST_BIND=127.0.0.1
TGTLDR_HOST_WEB_PORT=3000

# Optional. When placing TGTLDR behind a reverse proxy, set this to the final
# public origin, for example https://tgtldr.example.com.
TGTLDR_WEB_ORIGIN=

# Optional. Markdown workspace for AI-maintained long-term LLM Wiki pages.
# Defaults to /var/lib/tgtldr/wiki inside the app volume.
TGTLDR_LLM_WIKI_DIR=
